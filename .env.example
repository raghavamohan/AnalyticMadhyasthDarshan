# Copy to `.env` in the repository root and replace placeholders.
# `.env` is gitignored; this file is the committed template.
#
# Used by:
#   python Scripts/_cloudflare_performance.py
#   infra/worker/_fetch_turnstile_secret.py (and related Turnstile helpers)
#   R2 / S3 clients (AWS CLI, boto3, rclone, etc.) — when you wire storage scripts
#
# Worker runtime secrets (GITHUB_TOKEN, OAuth) live in Wrangler — see infra/worker/README.md

# Cloudflare account — R2 → Overview (right column) or any zone dashboard URL
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Cloudflare API token — https://dash.cloudflare.com/profile/api-tokens
# Custom token: Zone (Cache Purge, Cache Rules, …) on analyticmadhyasthdarshan.org
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Optional — zone for analyticmadhyasthdarshan.org (auto-lookup works if omitted)
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id_here

# R2 — S3-compatible API credentials
# Create in: R2 → Manage R2 API Tokens → Create API token (Object Read & Write, or tighter)
# Endpoint shown in the dashboard: https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ENDPOINT=https://your_cloudflare_account_id_here.r2.cloudflarestorage.com
R2_BUCKET_NAME=your_bucket_name_here
R2_REGION=auto

# Optional aliases for tools that expect AWS-style names (boto3, aws cli, some SDKs)
AWS_ACCESS_KEY_ID=your_r2_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
AWS_ENDPOINT_URL=https://your_cloudflare_account_id_here.r2.cloudflarestorage.com
AWS_REGION=auto

# GitHub — local maintainer scripts only (_bootstrap_proposal_study.py, CI helpers)
# Fine-grained or classic PAT with Issues, Contents, Pull requests on this repo
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPOSITORY=raghavamohan/AnalyticMadhyasthDarshan
